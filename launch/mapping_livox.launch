<launch>
	<!-- Launch file for Livox MID360 LiDAR (sensor_msgs::PointCloud2)-->

	<arg name="rviz" default="true"/>

	<rosparam command="load" file="$(find fastlio)/config/livox.yaml"/>

	<remap from="/Odometry" to="/fastlio/odometry"/>
	<remap from="/Laser_map" to="/fastlio/laser_map"/>
	<remap from="/path" to="/fastlio/path"/>
	<remap from="/path_updated" to="/fastlio/path_updated"/>
	<remap from="/aft_pgo_path" to="/pgo/path"/>
	<node pkg="fastlio" type="fastlio_mapping" name="laserMapping" output="screen"/>

	<group if="$(arg rviz)">
		<node launch-prefix="nice" pkg="rviz" type="rviz" name="rviz" args="-d $(find fastlio)/config/fastlio.rviz"/>
	</group>

</launch>
